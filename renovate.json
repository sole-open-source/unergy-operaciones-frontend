{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits"
  ],
  "timezone": "America/Bogota",
  "schedule": ["before 6am on monday"],
  "labels": ["dependencies"],
  "prConcurrentLimit": 10,
  "rangeStrategy": "bump",
  "packageRules": [
    {
      "description": "Auto-merge patch and minor updates once CI passes",
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    },
    {
      "description": "Require manual review for major updates (separate PRs)",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "addLabels": ["major-update"]
    },
    {
      "description": "Group Vue ecosystem (vue, vue-router, vuedraggable, vue-chartjs, @vitejs/plugin-vue)",
      "matchPackageNames": [
        "vue",
        "vue-router",
        "vuedraggable",
        "vue-chartjs",
        "@vitejs/plugin-vue"
      ],
      "groupName": "vue ecosystem"
    },
    {
      "description": "Group PrimeVue packages",
      "matchPackageNames": ["primevue", "@primevue/themes", "primeicons"],
      "groupName": "primevue ecosystem"
    },
    {
      "description": "Group chart.js related packages",
      "matchPackageNames": ["chart.js", "vue-chartjs"],
      "groupName": "chart.js"
    },
    {
      "description": "Group build tooling (vite, postcss, tailwind, autoprefixer)",
      "matchPackageNames": [
        "vite",
        "postcss",
        "tailwindcss",
        "autoprefixer"
      ],
      "groupName": "build tooling"
    },
    {
      "description": "Keep axios on its own so HTTP client changes are reviewed in isolation",
      "matchPackageNames": ["axios"],
      "groupName": "axios"
    }
  ],
  "vulnerabilityAlerts": {
    "labels": ["security"],
    "automerge": false
  }
}
