{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://backend-production-63d8.up.railway.app/api/$1"
    },
    {
      "source": "/monitoreo/(.*)",
      "destination": "https://backend-production-63d8.up.railway.app/monitoreo/$1"
    },
    {
      "source": "/monitoreo",
      "destination": "https://backend-production-63d8.up.railway.app/monitoreo"
    },
    {
      "source": "/static/(.*)",
      "destination": "https://backend-production-63d8.up.railway.app/static/$1"
    },
    {
      "source": "/((?!api/|monitoreo|static/).*)",
      "destination": "/index.html"
    }
  ],
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite"
}
