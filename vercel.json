{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://backend-production-63d8.up.railway.app/api/:path*"
    },
    {
      "source": "/monitoreo/:path*",
      "destination": "https://backend-production-63d8.up.railway.app/monitoreo/:path*"
    },
    {
      "source": "/monitoreo",
      "destination": "https://backend-production-63d8.up.railway.app/monitoreo"
    },
    {
      "source": "/((?!api/|monitoreo).*)",
      "destination": "/index.html"
    }
  ],
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite"
}
