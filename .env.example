# ---------------------------------------------------------------------------
# Variables de entorno - operaciones-frontend
#
# Copia este archivo a `.env` para desarrollo local:
#     cp .env.example .env
#
# `.env`, `.env.local` y `.env.production` estan en .gitignore y NO deben
# subirse al repositorio. Solo las variables con prefijo VITE_ quedan
# expuestas al codigo del cliente (Vite); el resto solo se usa en build/proxy.
# ---------------------------------------------------------------------------

# URL base del backend de operaciones. La usa el cliente (axios/fetch) y el
# proxy de desarrollo de Vite para /api, /monitoreo, etc.
VITE_API_URL=http://localhost:8000

# URL base para el cliente axios (src/api/client.js). Si se omite se usa
# el valor por defecto "/api/v1" (resuelto a traves del proxy de Vite).
VITE_API_BASE_URL=/api/v1

# Destino del proxy de desarrollo para el servicio EVO (/api/v1/evo).
# Solo se usa en local; en produccion el enrutamiento lo maneja nginx.
EVO_API_URL=http://localhost:18800

# Token enviado en la cabecera X-EVO-Token hacia el servicio EVO a traves
# del proxy de desarrollo. Dejar vacio si no se requiere autenticacion local.
EVO_API_TOKEN=
